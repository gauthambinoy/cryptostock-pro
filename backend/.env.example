# Database
# Local demo: sqlite:///./data/quantumledger.db
# Production: postgresql://user:password@host:5432/quantumledger
DATABASE_URL=sqlite:///./data/quantumledger.db

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-64-character-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
DEBUG=true
# Pydantic parses list settings from JSON.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# Cache / background workflows
REDIS_URL=redis://localhost:6379/0

# Market/news data APIs (optional; improve rate limits and coverage)
COINGECKO_API_KEY=
ALPHA_VANTAGE_KEY=
NEWSAPI_KEY=
FRED_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# AI assistant (optional)
ANTHROPIC_API_KEY=

# Email/SMS alerts (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@quantumledger.ai
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payments/subscriptions (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=
